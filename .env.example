# Weather API Configuration
# Reemplaza con tu propia API key de https://www.weatherapi.com/
# Importante: las variables VITE_* se exponen en el frontend (no son secretos reales).
# Para claves sensibles, usa un backend/proxy y no las envíes al navegador.

# API Key para WeatherAPI (requerido)
VITE_WEATHER_API_KEY=tu_api_key_aqui
